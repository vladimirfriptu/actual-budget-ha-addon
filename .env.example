# Copy to .env and fill in only if you need to override the deploy target.
# The MVP has no add-on options — Actual sets its server password in-UI on first
# run — so .env is OPTIONAL. Defaults live in scripts/ha.sh.

# HAOS host the add-on is deployed to (also used by `just smoke`).
# HA_HOST=192.168.68.140
# HA_PORT=22

# SSH key authorized on the HAOS host for root deploys.
# HA_KEY=$HOME/.config/ha-deploy/id_ed25519

# Installed add-on slug (local add-ons get a `local_` prefix).
# SLUG=local_actual_budget
